{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "matomo/padrao-comportamental",
  "description": "O que o cidadão acessa logo após a Home — Transitions.getTransitionsForPageUrl fixo na Home, categorizado por classificar_jornada. 1 chave por período fixo — ver ADR-007.",
  "type": "object",
  "required": ["dia", "semana", "mes", "ano"],
  "properties": {
    "dia": { "$ref": "#/definitions/periodo" },
    "semana": { "$ref": "#/definitions/periodo" },
    "mes": { "$ref": "#/definitions/periodo" },
    "ano": { "$ref": "#/definitions/periodo" }
  },
  "definitions": {
    "periodo": {
      "type": "object",
      "required": ["distribuicao", "topDestinos"],
      "properties": {
        "distribuicao": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tipo", "acessos", "participacaoPct"],
            "properties": {
              "tipo": { "type": "string" },
              "acessos": { "type": "integer", "minimum": 0 },
              "participacaoPct": { "type": "number", "minimum": 0 }
            }
          }
        },
        "topDestinos": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "required": ["pagina", "tipo", "acessos"],
            "properties": {
              "pagina": { "type": "string" },
              "tipo": { "type": "string" },
              "acessos": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
