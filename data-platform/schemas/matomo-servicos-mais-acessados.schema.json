{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "matomo/servicos-mais-acessados",
  "description": "Serviços reais mais acessados do portal, 1 chave por período fixo — ver ADR-007",
  "type": "object",
  "required": ["dia", "semana", "mes", "ano"],
  "properties": {
    "dia": { "$ref": "#/definitions/linhas" },
    "semana": { "$ref": "#/definitions/linhas" },
    "mes": { "$ref": "#/definitions/linhas" },
    "ano": { "$ref": "#/definitions/linhas" }
  },
  "definitions": {
    "linhas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["servico", "path", "visitas"],
        "properties": {
          "servico": { "type": "string" },
          "path": { "type": "string" },
          "visitas": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
