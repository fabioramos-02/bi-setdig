{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "matomo/dispositivos",
  "description": "1 chave por período fixo (dia/semana/mes/ano) — ver ADR-007",
  "type": "object",
  "required": ["dia", "semana", "mes", "ano"],
  "properties": {
    "dia": { "$ref": "#/definitions/linhas" },
    "semana": { "$ref": "#/definitions/linhas" },
    "mes": { "$ref": "#/definitions/linhas" },
    "ano": { "$ref": "#/definitions/linhas" }
  },
  "definitions": {
    "linhas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dispositivo", "visitas"],
        "properties": { "dispositivo": { "type": "string" }, "visitas": { "type": "integer", "minimum": 0 } }
      }
    }
  }
}
