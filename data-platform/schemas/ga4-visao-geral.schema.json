{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ga4/visao-geral",
  "description": "1 chave por período fixo (dia/semana/mes/ano) — ver ADR-007 (v2)",
  "type": "object",
  "required": ["dia", "semana", "mes", "ano"],
  "properties": {
    "dia": { "$ref": "#/definitions/linhas" },
    "semana": { "$ref": "#/definitions/linhas" },
    "mes": { "$ref": "#/definitions/linhas" },
    "ano": { "$ref": "#/definitions/linhas" }
  },
  "definitions": {
    "linhas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["newVsReturning", "activeUsers"],
        "properties": {
          "newVsReturning": { "type": "string" },
          "activeUsers": { "type": "integer", "minimum": 0 },
          "sessions": { "type": "integer", "minimum": 0 },
          "screenPageViews": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
