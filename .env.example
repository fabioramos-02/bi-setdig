# Credenciais do data-platform (Fase 2 — ver docs/fases/03-fase-2-data-platform.md).
# Nomes idênticos aos já usados em matomo/matomo-analytics-dashboard/config.py
# e bench-carta/src/config.py — copiar valor real de lá ou pedir pra STI.
#
# Matomo/GA4 agora TAMBÉM são lidas em runtime pelos Route Handlers
# src/app/api/analytics/{portal-ms,ms-digital}/route.ts — exceção pontual ao
# ADR-001, só pro modo "Intervalo de datas" (ver ADR-010). Por isso essas
# envs (não as de Postgres) precisam existir também no painel da Vercel
# (Production + Preview), sem prefixo NEXT_PUBLIC_ — só o processo
# server-side do Route Handler as lê, nunca vão pro bundle do browser.

# --- Matomo (Portal Único) ---
MATOMO_URL=https://webanalytics.ms.gov.br/
MATOMO_SITE_ID=298
MATOMO_TOKEN=

# --- Google Analytics 4 (MS Digital App) ---
# OAuth2 hoje (mesmo padrão do matomo/bench-carta). Trocar por service account
# é um risco listado na Fase 2 — não bloqueia o scaffold inicial.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_PROPERTY_ID=

# --- Postgres (Cartas de Serviço — exige VPN da SETDIG) ---
HOST=localhost
PORT=5432
USER=
PASSWORD=
BANCO=postgres
